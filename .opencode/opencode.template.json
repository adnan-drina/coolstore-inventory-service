{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "nemotron": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MaaS Nemotron",
      "models": {
        "nemotron-3-nano-30b-a3b": {
          "name": "NVIDIA Nemotron (Local GPU)",
          "limit": { "context": 131072, "output": 4096 }
        }
      },
      "options": {
        "apiKey": "YOUR_API_KEY",
        "baseURL": "YOUR_MAAS_ROUTE/maas/nemotron-3-nano-30b-a3b/v1"
      }
    },
    "gpt-oss": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MaaS gpt-oss",
      "models": {
        "gpt-oss-20b": {
          "name": "OpenAI gpt-oss-20b (Local GPU)",
          "limit": { "context": 8192, "output": 4096 }
        }
      },
      "options": {
        "apiKey": "YOUR_API_KEY",
        "baseURL": "YOUR_MAAS_ROUTE/maas/gpt-oss-20b/v1"
      }
    },
    "gpt-4o": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MaaS GPT-4o",
      "models": {
        "gpt-4o": {
          "name": "OpenAI GPT-4o (External)",
          "limit": { "context": 128000, "output": 16384 }
        }
      },
      "options": {
        "apiKey": "YOUR_API_KEY",
        "baseURL": "YOUR_MAAS_ROUTE/maas/gpt-4o/v1"
      }
    },
    "gpt-4o-mini": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MaaS GPT-4o Mini",
      "models": {
        "gpt-4o-mini": {
          "name": "OpenAI GPT-4o Mini (External)",
          "limit": { "context": 128000, "output": 16384 }
        }
      },
      "options": {
        "apiKey": "YOUR_API_KEY",
        "baseURL": "YOUR_MAAS_ROUTE/maas/gpt-4o-mini/v1"
      }
    }
  },
  "model": "nemotron/nemotron-3-nano-30b-a3b",
  "small_model": "gpt-4o-mini/gpt-4o-mini",
  "mcp": {
    "openshift": {
      "type": "remote",
      "url": "http://openshift-mcp.coding-assistant.svc:8000/mcp",
      "enabled": true,
      "timeout": 10000
    }
  },
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "edit": "ask",
    "write": "ask",
    "bash": "ask",
    "webfetch": "ask",
    "*_mcp_*": "ask"
  }
}
